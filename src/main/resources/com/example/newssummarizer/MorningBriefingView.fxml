<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Separator?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.newssummarizer.MorningBriefingController"
      styleClass="feature-view">

    <!-- Hero header -->
    <VBox styleClass="hero">
        <Label text="FRONT PAGE" styleClass="hero-eyebrow"/>
        <Label text="Morning Briefing" styleClass="view-title"/>
        <Label text="A fresh round-up of the day's top stories. Then go deeper on whatever caught your eye." styleClass="view-subtitle" wrapText="true"/>
        <Region styleClass="hero-rule"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Get Today's Briefing" styleClass="action-btn" onAction="#onGetBriefing"/>
    </HBox>

    <Label text="TODAY'S BRIEFING" styleClass="field-label"/>
    <StackPane VBox.vgrow="ALWAYS" styleClass="result-pane">
        <ProgressIndicator fx:id="briefingProgress" maxWidth="64" maxHeight="64" visible="false"/>
        <TextArea fx:id="briefingArea" styleClass="result-area" wrapText="true" editable="false"
                  promptText="Click the button above to fetch today's top stories..."/>
    </StackPane>

    <Separator/>

    <Label text="DEEP DIVE" styleClass="field-label"/>
    <HBox spacing="10">
        <TextField fx:id="deepDiveField" promptText="Enter a topic to explore further..."
                   styleClass="input-field" HBox.hgrow="ALWAYS" onAction="#onDeepDive"/>
        <Button text="Search" styleClass="action-btn" onAction="#onDeepDive"/>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS" styleClass="result-pane">
        <ProgressIndicator fx:id="deepDiveProgress" maxWidth="64" maxHeight="64" visible="false"/>
        <TextArea fx:id="deepDiveArea" styleClass="result-area" wrapText="true" editable="false"
                  promptText="Deep dive results will appear here..."/>
    </StackPane>

</VBox>
